---
type SectionVariant = 'gradient' | 'js' | 'js-dark' | 'zurich' | 'black' | 'white' | 'gray' | 'transparent';
type SectionPadding = 'sm' | 'md' | 'lg' | 'none';

interface Props {
  variant?: SectionVariant;
  class?: string;
  containerClass?: string;
  padding?: SectionPadding;
  id?: string;
}

const {
  variant = 'white',
  class: className = '',
  containerClass = '',
  padding = 'md',
  id,
} = Astro.props;

const variantStyles: Record<SectionVariant, string> = {
  gradient: 'bg-gradient-to-br from-js to-js-dark',
  js: 'bg-js',
  'js-dark': 'bg-js-dark',
  zurich: 'bg-zurich',
  black: 'bg-black text-white',
  white: 'bg-white',
  gray: 'bg-gray-50',
  transparent: 'bg-transparent',
};

const paddingStyles: Record<SectionPadding, string> = {
  none: '',
  sm: 'py-4 lg:py-8',
  md: 'py-4 lg:py-16',
  lg: 'py-4 lg:py-24',
};
---

<section id={id} class={`w-full ${variantStyles[variant]} ${paddingStyles[padding]} ${className} animate-fade-in`}>
  <div class={`container mx-auto px-6 ${containerClass}`}>
    <slot />
  </div>
</section>
