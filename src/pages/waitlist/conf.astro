---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/astro/Section.astro';
---

<PageLayout title="ZurichJS Conf 2026 Waitlist" description="Join the waitlist for ZurichJS Conf 2026.">
  <Section variant="gradient" padding="lg">
    <div class="text-center animate-fade-in-up max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        ZurichJS <span class="bg-white/20 px-2 rounded">Conf 2026</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-800">
        Tickets are selling fast. Join the waitlist to be notified when more become available.
      </p>
    </div>
  </Section>

  <Section variant="white" padding="lg">
    <div class="max-w-xl mx-auto">
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 animate-fade-in-up">
        <h2 class="text-2xl font-bold mb-2 text-center">Join the Waitlist</h2>
        <p class="text-gray-600 mb-8 text-center">
          Enter your email to be notified when tickets are available.
        </p>

        <form class="space-y-4" action="/api/waitlist/conf" method="POST">
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="form-input w-full"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="form-input w-full"
              placeholder="you@example.com"
            />
          </div>
          <button
            type="submit"
            class="w-full bg-gray-900 text-white py-3 px-6 rounded-xl font-semibold text-lg hover:bg-gray-800 transition-all duration-200 hover:shadow-lg"
          >
            Join Waitlist
          </button>
        </form>

        <p class="text-xs text-gray-500 mt-4 text-center">
          We'll only use your email to notify you about ZurichJS Conf 2026 ticket availability.
        </p>
      </div>
    </div>
  </Section>
</PageLayout>
