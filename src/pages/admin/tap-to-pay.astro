---
import PageLayout from '../../layouts/PageLayout.astro';
export const prerender = false;
---

<PageLayout title="Tap to Pay | Admin | ZurichJS" description="Tap to pay management." noindex={true}>
  <div id="admin-tap-to-pay-app">
    <!-- Admin tap to pay React island will be mounted here -->
    <div class="container mx-auto px-4 py-8 pt-16">
      <h1 class="text-3xl font-bold mb-4">Tap to Pay</h1>
      <p class="text-gray-600">Loading tap to pay...</p>
    </div>
  </div>
</PageLayout>
