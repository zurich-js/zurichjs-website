---
export const prerender = false;

import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/astro/Section.astro';
import { getWorkshops } from '../../data/workshops';
import { getSpeakerById } from '../../sanity/queries/speakers';
import TicketSelection from '../../components/workshop/TicketSelection';
import { Image } from 'astro:assets';

const { slug } = Astro.params;

if (!slug) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const workshops = getWorkshops();
const workshop = workshops.find(w => w.id === slug);

if (!workshop) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const speaker = await getSpeakerById(workshop.speakerId);

// Fetch additional speakers if speakerIds is defined
let additionalSpeakers: Awaited<ReturnType<typeof getSpeakerById>>[] = [];
if (workshop.speakerIds && workshop.speakerIds.length > 0) {
  additionalSpeakers = await Promise.all(
    workshop.speakerIds
      .filter(id => id !== workshop.speakerId)
      .map(id => getSpeakerById(id))
  );
}

const allSpeakers = [speaker, ...additionalSpeakers].filter(Boolean);
---

<PageLayout
  title={`${workshop.title} | ZurichJS Workshops`}
  description={workshop.description}
  keywords={['ZurichJS workshop', workshop.title, 'JavaScript workshop Zurich', workshop.tag]}
>
  <!-- Hero -->
  <Section variant="gradient" padding="lg">
    <div class="animate-fade-in-up max-w-4xl mx-auto">
      <a href="/workshops" class="text-gray-700 hover:text-gray-900 transition-colors flex items-center gap-1 text-sm font-medium mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        All Workshops
      </a>
      <div class="flex items-center gap-2 mb-4">
        {workshop.state === 'confirmed' ? (
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-200 text-green-800">
            Confirmed
          </span>
        ) : (
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-200 text-yellow-800">
            Gauging Interest
          </span>
        )}
        {workshop.tag && (
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-white/60 text-gray-700">
            {workshop.tag}
          </span>
        )}
      </div>
      <h1 class="text-3xl md:text-5xl font-bold mb-2">{workshop.title}</h1>
      {workshop.subtitle && (
        <p class="text-lg md:text-xl text-gray-700 mb-6">{workshop.subtitle}</p>
      )}
      <div class="flex flex-wrap gap-6 text-gray-800">
        <p class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          {workshop.dateInfo}
        </p>
        <p class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          {workshop.timeInfo}
        </p>
        <p class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          {workshop.locationInfo}
        </p>
        <p class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          Max {workshop.maxAttendees} attendees
        </p>
      </div>
    </div>
  </Section>

  <!-- Workshop Content -->
  <Section variant="white" padding="lg">
    <div class="max-w-4xl mx-auto animate-fade-in-up">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          {workshop.image && (
            <div class="rounded-2xl overflow-hidden mb-8">
              <Image src={workshop.image} alt={workshop.title} width={800} height={450} class="w-full object-cover" />
            </div>
          )}

          <div class="mb-8">
            <h2 class="text-2xl font-bold mb-4">About This Workshop</h2>
            <div class="prose prose-gray max-w-none">
              <p class="text-gray-600 leading-relaxed whitespace-pre-line">{workshop.description}</p>
            </div>
          </div>

          <!-- Instructor(s) -->
          {allSpeakers.length > 0 && (
            <div class="mb-8">
              <h2 class="text-2xl font-bold mb-6">{allSpeakers.length > 1 ? 'Instructors' : 'Instructor'}</h2>
              <div class="space-y-6">
                {allSpeakers.map((s) => s && (
                  <div class="flex items-start gap-4 bg-gray-50 rounded-2xl p-6 border border-gray-100">
                    <a href={`/speakers/${s.id}`} class="shrink-0">
                      <Image src={s.image} alt={s.name} width={64} height={64} class="w-16 h-16 rounded-xl object-cover" />
                    </a>
                    <div>
                      <a href={`/speakers/${s.id}`} class="text-lg font-bold hover:text-blue-600 transition-colors">{s.name}</a>
                      {s.title && <p class="text-sm text-gray-500">{s.title}</p>}
                      {s.company && <p class="text-xs text-gray-400">{s.company}</p>}
                      {s.bio && <p class="text-sm text-gray-600 mt-2 line-clamp-3">{s.bio}</p>}
                      <div class="flex gap-3 mt-2">
                        {s.twitter && (
                          <a href={`https://twitter.com/${s.twitter}`} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                          </a>
                        )}
                        {s.github && (
                          <a href={`https://github.com/${s.github}`} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                          </a>
                        )}
                        {s.linkedin && (
                          <a href={s.linkedin.startsWith('http') ? s.linkedin : `https://linkedin.com/in/${s.linkedin}`} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                          </a>
                        )}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="sticky top-32 space-y-6">
            <!-- Workshop Details Card -->
            <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
              <h3 class="font-bold mb-4">Workshop Details</h3>
              <dl class="space-y-3 text-sm">
                <div>
                  <dt class="text-gray-500">Date</dt>
                  <dd class="font-medium">{workshop.dateInfo}</dd>
                </div>
                <div>
                  <dt class="text-gray-500">Time</dt>
                  <dd class="font-medium">{workshop.timeInfo}</dd>
                </div>
                <div>
                  <dt class="text-gray-500">Location</dt>
                  <dd class="font-medium">{workshop.locationInfo}</dd>
                </div>
                <div>
                  <dt class="text-gray-500">Max Attendees</dt>
                  <dd class="font-medium">{workshop.maxAttendees}</dd>
                </div>
                <div>
                  <dt class="text-gray-500">Status</dt>
                  <dd>
                    {workshop.state === 'confirmed' ? (
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        Confirmed
                      </span>
                    ) : (
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                        Gauging Interest
                      </span>
                    )}
                  </dd>
                </div>
              </dl>
            </div>

            <!-- Ticket Selection -->
            {workshop.state === 'confirmed' && (
              <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
                <h3 class="font-bold mb-4">Get Your Ticket</h3>
                <TicketSelection
                  client:visible
                  options={[{
                    id: workshop.id,
                    title: 'Workshop Ticket',
                    description: `Ticket for ${workshop.title}`,
                    price: 0,
                    features: ['Hands-on workshop', 'Expert instruction', 'Certificate of completion'],
                    ticketType: 'workshop' as const,
                    workshopId: workshop.id,
                  }]}
                  workshopId={workshop.id}
                  ticketType="workshop"
                />
              </div>
            )}

            {workshop.state === 'interest' && (
              <div class="bg-yellow-50 rounded-2xl p-6 border border-yellow-100">
                <h3 class="font-bold mb-2">Interested?</h3>
                <p class="text-sm text-gray-600 mb-4">
                  This workshop is in the planning phase. Let us know you are interested so we can confirm it!
                </p>
                <a
                  href={`mailto:hello@zurichjs.com?subject=Interest in workshop: ${workshop.title}`}
                  class="block w-full text-center bg-gray-900 text-white px-6 py-3 rounded-xl font-bold hover:bg-gray-800 transition-all duration-200"
                >
                  Express Interest
                </a>
              </div>
            )}

            <!-- Instructor Quick View -->
            {speaker && (
              <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
                <h3 class="font-bold mb-4">Instructor</h3>
                <a href={`/speakers/${speaker.id}`} class="flex items-center gap-3 hover:bg-gray-100 rounded-lg p-2 -mx-2 transition-colors">
                  <Image src={speaker.image} alt={speaker.name} width={48} height={48} class="w-12 h-12 rounded-full object-cover" />
                  <div>
                    <p class="font-medium">{speaker.name}</p>
                    {speaker.title && <p class="text-xs text-gray-500">{speaker.title}</p>}
                    <p class="text-xs text-blue-600 mt-0.5">{speaker.talkCount} talks at ZurichJS</p>
                  </div>
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </Section>
</PageLayout>
