---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/astro/Section.astro';
import LandingHero from '../components/sections/LandingHero';
import UpcomingEvents from '../components/sections/UpcomingEvents';
import UpcomingWorkshops from '../components/sections/UpcomingWorkshops';
import CommunityValues from '../components/sections/CommunityValues';
import Partners from '../components/sections/Partners';
import JoinCTA from '../components/sections/JoinCTA';
import { getUpcomingEvents } from '../sanity/queries/events';
import { getSpeakers, getSpeakerById } from '../sanity/queries/speakers';
import { getStats } from '../sanity/queries/stats';
import { getPartners } from '../data';
import { getUpcomingWorkshops } from '../data/workshops';
import { generateHomePageStructuredData } from '../utils/structuredData';

const stats = await getStats();
const upcomingEvents = await getUpcomingEvents();
const speakers = await getSpeakers({ shouldFilterVisible: true });
const partners = getPartners();
const upcomingWorkshops = getUpcomingWorkshops();

// Fetch speaker data for each workshop
const workshopsWithSpeakers = await Promise.all(
  upcomingWorkshops.map(async (workshop) => {
    const speaker = await getSpeakerById(workshop.speakerId);
    return { ...workshop, speaker };
  })
);

const structuredData = generateHomePageStructuredData();
---

<PageLayout
  title="ZurichJS | JavaScript & TypeScript Meetup Community in Zurich, Switzerland"
  description="Join ZurichJS, the premier JavaScript and TypeScript community in Zurich. Free meetups, expert speakers, workshops on React, Node.js, Vue, Angular, AI, and modern web development."
  keywords={[
    'JavaScript Zurich', 'TypeScript Zurich', 'Web Development Zurich',
    'React Meetup Zurich', 'Node.js Zurich', 'Frontend Development Zurich',
    'Tech Meetup Zurich', 'Programming Events Zurich', 'Developer Community Switzerland',
  ]}
  geo={{ region: 'CH-ZH', placename: 'Zurich', position: '47.3769;8.5417' }}
  structuredData={structuredData}
  ogImage="https://zurichjs.com/api/og/home"
  twitter={{ cardType: 'summary_large_image', site: '@zurichjs' }}
>
  <LandingHero
    client:load
    upcomingEvents={upcomingEvents}
    stats={stats}
    upcomingWorkshops={workshopsWithSpeakers}
    speakers={speakers}
  />

  <UpcomingEvents client:visible events={upcomingEvents} />

  <UpcomingWorkshops client:visible workshops={workshopsWithSpeakers} />

  <CommunityValues client:visible />

  <Partners client:visible partners={partners} />

  <JoinCTA client:visible />
</PageLayout>
