---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/astro/Section.astro';
import { Image } from 'astro:assets';
import { getStats } from '../sanity/queries/stats';

const stats = await getStats();

const teamMembers = [
  {
    name: 'Faris Aziz',
    role: 'Founder',
    image: '/images/team/faris.jpg',
    bio: 'Software engineer and community builder passionate about JavaScript and the Zurich tech scene.',
    linkedin: 'https://www.linkedin.com/in/farisaziz/',
  },
  {
    name: 'Hugo Sousa',
    role: 'Co-Organizer',
    image: '/images/team/hugo.jpg',
    bio: 'Developer and meetup enthusiast helping grow the JavaScript community in Zurich.',
    linkedin: 'https://www.linkedin.com/in/hugosousa/',
  },
];

const milestones = [
  { year: '2023', title: 'ZurichJS Founded', description: 'First meetup held with a small group of JavaScript enthusiasts in Zurich.' },
  { year: '2023', title: 'Growing Community', description: 'Regular monthly meetups established with a growing roster of speakers and venues.' },
  { year: '2024', title: 'Partnerships Formed', description: 'Partnered with local companies and international conferences to bring more value to members.' },
  { year: '2025', title: 'Workshops Launched', description: 'Introduced hands-on workshops alongside regular meetup talks.' },
  { year: '2026', title: 'ZurichJS Conf Announced', description: 'Planning the first ever ZurichJS Conference for 2026.' },
];
---

<PageLayout
  title="About | ZurichJS"
  description="Learn about ZurichJS, Zurich's JavaScript and TypeScript community."
  keywords={['ZurichJS', 'JavaScript Zurich', 'TypeScript Zurich', 'about', 'developer community', 'meetup Zurich']}
>
  <!-- Hero -->
  <Section variant="gradient" padding="lg">
    <div class="text-center animate-fade-in-up max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        About <span class="bg-white/20 px-2 rounded">ZurichJS</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-800">
        Zurich's home for JavaScript and TypeScript developers. We bring together
        engineers, designers, and tech enthusiasts for monthly meetups, workshops, and community events.
      </p>
    </div>
  </Section>

  <!-- About the Community -->
  <Section variant="white" padding="lg">
    <div class="max-w-4xl mx-auto animate-fade-in-up">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">The Community</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            ZurichJS is Zurich's premier JavaScript and TypeScript community. We host free, monthly meetups
            where developers of all experience levels come together to learn, share, and connect.
          </p>
          <p class="text-gray-700 leading-relaxed mb-4">
            Whether you are building with React, Vue, Angular, Node.js, Deno, or any other part of the
            JavaScript ecosystem, there is a place for you here. Our events feature talks from local and
            international speakers, hands-on workshops, and plenty of networking time.
          </p>
          <p class="text-gray-700 leading-relaxed">
            All of our meetups are free and open to everyone. We believe in making tech education accessible
            and building a welcoming, inclusive community.
          </p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
          <div class="grid grid-cols-2 gap-6 text-center">
            <div>
              <div class="text-3xl font-bold text-js-dark">{stats.members?.toLocaleString() || '2,000+'}</div>
              <div class="text-sm text-gray-500 mt-1">Members</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-js-dark">{stats.eventsHosted || '30+'}</div>
              <div class="text-sm text-gray-500 mt-1">Events Hosted</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-js-dark">{stats.speakersToDate || '50+'}</div>
              <div class="text-sm text-gray-500 mt-1">Speakers</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-js-dark">{stats.totalAttendees?.toLocaleString() || '3,000+'}</div>
              <div class="text-sm text-gray-500 mt-1">Total Attendees</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Our Mission -->
  <Section variant="black" padding="lg">
    <div class="max-w-4xl mx-auto text-center animate-fade-in-up">
      <h2 class="text-3xl font-bold mb-8">Our Mission</h2>
      <p class="text-xl text-gray-300 leading-relaxed mb-12 max-w-2xl mx-auto">
        To foster a thriving, inclusive JavaScript community in Zurich where developers can learn,
        share knowledge, and grow their careers together.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
          <div class="w-12 h-12 bg-js rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Knowledge Sharing</h3>
          <p class="text-gray-400 text-sm">Talks and workshops from industry experts on the latest in JavaScript, TypeScript, and web development.</p>
        </div>
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
          <div class="w-12 h-12 bg-js rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Networking</h3>
          <p class="text-gray-400 text-sm">Connect with fellow developers, find collaborators, and build lasting professional relationships.</p>
        </div>
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
          <div class="w-12 h-12 bg-js rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Inclusivity</h3>
          <p class="text-gray-400 text-sm">A welcoming space for developers of all backgrounds and experience levels to learn and grow.</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Team Members -->
  <Section variant="white" padding="lg">
    <div class="max-w-4xl mx-auto animate-fade-in-up">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Meet the Team</h2>
        <p class="text-gray-600 max-w-xl mx-auto">
          The people behind ZurichJS who organize events, manage the community, and keep things running.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-2xl mx-auto">
        {teamMembers.map((member, i) => (
          <div class={`bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center animate-fade-in-up stagger-${i + 1}`}>
            <Image
              src={member.image}
              alt={member.name}
              width={112}
              height={112}
              class="w-28 h-28 rounded-full mx-auto mb-4 object-cover border-4 border-js/20"
            />
            <h3 class="text-xl font-bold text-gray-900">{member.name}</h3>
            <p class="text-js-dark font-medium mb-3">{member.role}</p>
            <p class="text-gray-600 text-sm mb-4">{member.bio}</p>
            <a
              href={member.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 text-sm font-medium transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Community Stats -->
  <Section variant="gray" padding="lg">
    <div class="max-w-4xl mx-auto animate-fade-in-up text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Community in Numbers</h2>
      <p class="text-gray-600 mb-12 max-w-xl mx-auto">
        Since our founding, ZurichJS has grown into one of the most active tech communities in Zurich.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 stagger-1 animate-fade-in-up">
          <div class="text-4xl font-bold text-js-dark mb-1">{stats.members?.toLocaleString() || '2,000+'}</div>
          <div class="text-gray-500 text-sm font-medium">Community Members</div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 stagger-2 animate-fade-in-up">
          <div class="text-4xl font-bold text-js-dark mb-1">{stats.eventsHosted || '30+'}</div>
          <div class="text-gray-500 text-sm font-medium">Events Hosted</div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 stagger-3 animate-fade-in-up">
          <div class="text-4xl font-bold text-js-dark mb-1">{stats.speakersToDate || '50+'}</div>
          <div class="text-gray-500 text-sm font-medium">Speakers Featured</div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 stagger-4 animate-fade-in-up">
          <div class="text-4xl font-bold text-js-dark mb-1">{stats.totalAttendees?.toLocaleString() || '3,000+'}</div>
          <div class="text-gray-500 text-sm font-medium">Total Attendees</div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Milestones Timeline -->
  <Section variant="white" padding="lg">
    <div class="max-w-3xl mx-auto animate-fade-in-up">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Journey</h2>
        <p class="text-gray-600">Key milestones in the ZurichJS story.</p>
      </div>
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5 bg-js/30"></div>

        {milestones.map((milestone, i) => (
          <div class={`relative flex items-start mb-10 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- Dot -->
            <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-4 h-4 bg-js rounded-full border-4 border-white shadow-sm z-10"></div>

            <!-- Content -->
            <div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:pr-8 md:text-right' : 'md:pl-8'}`}>
              <span class="inline-block bg-js/10 text-js-dark text-xs font-bold px-3 py-1 rounded-full mb-2">
                {milestone.year}
              </span>
              <h3 class="text-lg font-bold text-gray-900 mb-1">{milestone.title}</h3>
              <p class="text-gray-600 text-sm">{milestone.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section variant="gradient" padding="lg">
    <div class="text-center animate-fade-in-up max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Join the Community</h2>
      <p class="text-gray-800 text-lg mb-8">
        Come to your first meetup and see what ZurichJS is all about. All skill levels welcome.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://www.meetup.com/zurichjs/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-black text-white px-6 py-3 rounded-xl font-semibold hover:bg-gray-900 transition-colors"
        >
          Join on Meetup
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 bg-white/90 text-black px-6 py-3 rounded-xl font-semibold hover:bg-white transition-colors"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </Section>
</PageLayout>
