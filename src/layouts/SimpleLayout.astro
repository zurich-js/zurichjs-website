---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  ogImage?: string;
}

const { title, description, keywords, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} keywords={keywords} ogImage={ogImage}>
  <main class="flex-grow">
    <slot />
  </main>
</BaseLayout>
