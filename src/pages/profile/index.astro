---
import PageLayout from '../../layouts/PageLayout.astro';
export const prerender = false;
---

<PageLayout title="Profile | ZurichJS" description="Your ZurichJS profile." noindex={true}>
  <div id="profile-app">
    <!-- Profile React island will be mounted here -->
    <div class="container mx-auto px-4 py-8 pt-16">
      <h1 class="text-3xl font-bold mb-4">Your Profile</h1>
      <p class="text-gray-600">Loading profile...</p>
    </div>
  </div>
</PageLayout>
