---
import PageLayout from '../layouts/PageLayout.astro';
export const prerender = false;
---

<PageLayout title="Event Feedback | ZurichJS" description="Share your feedback about ZurichJS events.">
  <div id="event-feedback-app">
    <!-- EventFeedback React island will be mounted here -->
    <div class="container mx-auto px-4 py-8 pt-16">
      <h1 class="text-3xl font-bold mb-4">Event Feedback</h1>
      <p class="text-gray-600">Loading feedback form...</p>
    </div>
  </div>
</PageLayout>
