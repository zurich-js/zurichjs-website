---
import PageLayout from '../layouts/PageLayout.astro';
export const prerender = false;
---

<PageLayout title="T-Shirts | ZurichJS" description="Order ZurichJS t-shirts and merchandise.">
  <div id="tshirt-app">
    <!-- T-shirt wizard React island will be mounted here -->
    <div class="container mx-auto px-4 py-8 pt-16">
      <h1 class="text-3xl font-bold mb-8">ZurichJS T-Shirts</h1>
      <p class="text-gray-600">Loading t-shirt configurator...</p>
    </div>
  </div>
</PageLayout>
