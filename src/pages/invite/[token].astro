---
import PageLayout from '../../layouts/PageLayout.astro';
export const prerender = false;

const { token } = Astro.params;

if (!token) {
  return Astro.redirect('/invite');
}
---

<PageLayout title="Join ZurichJS" description="You've been invited to join ZurichJS!">
  <div id="invite-app" data-token={token}>
    <!-- Invite React island will be mounted here -->
    <div class="container mx-auto px-4 py-8 pt-16 text-center">
      <h1 class="text-3xl font-bold mb-4">Welcome to ZurichJS</h1>
      <p class="text-gray-600">Processing your invitation...</p>
    </div>
  </div>
</PageLayout>
