---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/astro/Section.astro';
---

<PageLayout
  title="Call for Volunteers | ZurichJS"
  description="Join the ZurichJS volunteer team and help build the JavaScript community in Zurich."
  keywords={['volunteer', 'zurichjs', 'javascript', 'community', 'zurich', 'help', 'contribute']}
  ogImage="/api/og/contact"
>
  <!-- Hero -->
  <Section variant="gradient" padding="lg">
    <div class="text-center animate-fade-in-up max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Call for <span class="bg-white/20 px-2 rounded">Volunteers</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-800">
        Help us build the best JavaScript community in Zurich. We're looking for passionate people to join our team.
      </p>
    </div>
  </Section>

  <!-- Why Volunteer -->
  <Section variant="white" padding="md">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 animate-fade-in-up">
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-js rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Grow Your Network</h3>
          <p class="text-gray-600 text-sm">Connect with developers, speakers, and industry professionals in the Zurich tech scene.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-js rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Build Experience</h3>
          <p class="text-gray-600 text-sm">Gain event organization, community management, and leadership experience.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-js rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Make an Impact</h3>
          <p class="text-gray-600 text-sm">Shape the JavaScript community in Zurich and help developers learn and grow.</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Volunteer Form -->
  <Section variant="gray" padding="lg" id="volunteer-form">
    <div class="max-w-2xl mx-auto">
      <div class="bg-white rounded-2xl shadow-lg p-8 md:p-10 animate-fade-in-up">
        <h2 class="text-2xl font-bold mb-2">Sign Up to Volunteer</h2>
        <p class="text-gray-600 mb-8">Fill out the form below and we'll get in touch with you about volunteer opportunities.</p>

        <form action="/api/submit-volunteer" method="POST" class="space-y-6">
          <!-- Name Fields -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="firstName" class="block text-sm font-semibold text-gray-700 mb-1">First Name <span class="text-red-500">*</span></label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                required
                class="form-input w-full"
                placeholder="Jane"
              />
            </div>
            <div>
              <label for="lastName" class="block text-sm font-semibold text-gray-700 mb-1">Last Name <span class="text-red-500">*</span></label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                required
                class="form-input w-full"
                placeholder="Doe"
              />
            </div>
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="form-input w-full"
              placeholder="jane@example.com"
            />
          </div>

          <!-- LinkedIn -->
          <div>
            <label for="linkedin" class="block text-sm font-semibold text-gray-700 mb-1">LinkedIn Profile</label>
            <input
              type="url"
              id="linkedin"
              name="linkedin"
              class="form-input w-full"
              placeholder="https://linkedin.com/in/janedoe"
            />
          </div>

          <!-- GitHub -->
          <div>
            <label for="github" class="block text-sm font-semibold text-gray-700 mb-1">GitHub Profile</label>
            <input
              type="url"
              id="github"
              name="github"
              class="form-input w-full"
              placeholder="https://github.com/janedoe"
            />
          </div>

          <!-- Availability -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Availability <span class="text-red-500">*</span></label>
            <div class="space-y-2">
              {[
                { value: 'monthly-meetups', label: 'Monthly meetups (weekday evenings)' },
                { value: 'conference', label: 'Annual conference (full day in September)' },
                { value: 'workshops', label: 'Workshops (weekend or evening sessions)' },
                { value: 'online', label: 'Online / remote tasks (content, social media, etc.)' },
                { value: 'flexible', label: 'Flexible - available as needed' },
              ].map((option) => (
                <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                  <input
                    type="checkbox"
                    name="availability"
                    value={option.value}
                    class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
                  />
                  <span class="text-gray-700">{option.label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Areas of Interest -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Areas of Interest</label>
            <div class="flex flex-wrap gap-2">
              {[
                'Event Setup', 'Registration Desk', 'Photography', 'Videography',
                'Social Media', 'Content Writing', 'Speaker Coordination',
                'Sponsorship Outreach', 'Web Development', 'Design',
                'Community Management', 'Workshop Facilitation',
              ].map((interest) => (
                <label class="inline-flex items-center gap-1.5 bg-gray-100 hover:bg-js/30 px-3 py-1.5 rounded-full text-sm font-medium cursor-pointer transition-colors has-[:checked]:bg-js has-[:checked]:text-gray-900">
                  <input
                    type="checkbox"
                    name="interests"
                    value={interest}
                    class="sr-only"
                  />
                  {interest}
                </label>
              ))}
            </div>
            <p class="text-xs text-gray-500 mt-2">Click to select areas you're interested in</p>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="form-input w-full resize-y"
              placeholder="Tell us about yourself, your experience, and what motivates you to volunteer..."
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-gray-900 text-white py-3 px-6 rounded-xl font-semibold text-lg hover:bg-gray-800 transition-all duration-200 hover:shadow-lg"
          >
            Submit Application
          </button>
        </form>
      </div>

      <!-- What Volunteers Do -->
      <div class="mt-12 animate-fade-in-up stagger-2">
        <h2 class="text-2xl font-bold mb-6 text-center">What Volunteers Do</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { title: 'Event Day Support', desc: 'Help with setup, registration, and teardown at meetups and conferences.' },
            { title: 'Content & Social Media', desc: 'Create posts, take photos, and help promote events online.' },
            { title: 'Speaker & Sponsor Coordination', desc: 'Help reach out to potential speakers and sponsors.' },
            { title: 'Community Engagement', desc: 'Welcome new members, facilitate networking, and moderate discussions.' },
          ].map((item) => (
            <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
              <h3 class="font-bold mb-1">{item.title}</h3>
              <p class="text-sm text-gray-600">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>
</PageLayout>
